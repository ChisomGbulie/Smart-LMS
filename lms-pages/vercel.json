{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": {
      "value": "@supabase_url"
    },
    "VITE_SUPABASE_ANON_KEY": {
      "value": "@supabase_anon_key"
    }
  }
}